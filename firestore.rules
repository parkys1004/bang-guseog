rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Primitive Helpers
    // ===============================================================
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "aimaster1004@gmail.com" || 
        (isEmailVerified() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // ===============================================================
    // Validation Blueprints
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'role', 'tier', 'createdAt']) &&
             data.keys().size() <= 7 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email == request.auth.token.email &&
             data.role in ['admin', 'user'] &&
             data.tier in ['free', 'silver', 'gold'] &&
             data.createdAt is string &&
             (!('subscriptionEndDate' in data) || data.subscriptionEndDate == null || (data.subscriptionEndDate is string && data.subscriptionEndDate.size() < 100));
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'receiverId', 'title', 'content', 'isRead', 'createdAt']) &&
             data.keys().size() <= 8 &&
             (data.senderId == request.auth.uid || data.senderId == 'system') &&
             data.receiverId is string && isValidId(data.receiverId) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             data.isRead == false &&
             data.createdAt is string;
    }

    function isValidMaterial(data) {
      return data.keys().hasAll(['title', 'description', 'contentUrl', 'category', 'requiredTier', 'authorId', 'createdAt']) &&
             data.keys().size() <= 12 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() < 2000 &&
             data.contentUrl is string && data.contentUrl.size() < 1000 &&
             data.category in ['ebook', 'prompt', 'service', 'advanced', 'webbuilder', 'thumbnail'] &&
             data.requiredTier in ['free', 'silver', 'gold'] &&
             data.authorId == request.auth.uid &&
             data.createdAt is string;
    }

    // ===============================================================
    // Match Blocks
    // ===============================================================

    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && (
        isAdmin() || 
        (isOwner(userId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photoURL']) &&
         incoming().email == existing().email &&
         incoming().role == existing().role &&
         incoming().tier == existing().tier)
      );
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read, list: if isSignedIn() && (
        resource.data.receiverId == request.auth.uid || 
        resource.data.senderId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() && isValidMessage(incoming());
      allow update: if isSignedIn() && (
        (isOwner(resource.data.receiverId) && incoming().diff(existing()).affectedKeys().hasOnly(['isRead'])) ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (isOwner(resource.data.receiverId) || isAdmin());
    }

    match /materials/{materialId} {
      allow read, list: if true;
      allow create: if isAdmin() && isValidMaterial(incoming());
      allow update: if isAdmin() && (
        incoming().authorId == existing().authorId &&
        incoming().createdAt == existing().createdAt
      );
      allow delete: if isAdmin();
    }

    // Config rules - Allow public read for master password verification by worker
    match /config/globalConfig {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /config/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /deleted_users/{email} {
      allow read: if isSignedIn() && (isAdmin() || request.auth.token.email.lower() == email);
      allow create: if isSignedIn() && (isAdmin() || request.auth.token.email.lower() == email);
      allow update, delete: if isAdmin();
    }
  }
}

