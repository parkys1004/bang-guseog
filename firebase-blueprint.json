{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and subscription information",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "tier": { "type": "string", "enum": ["free", "silver", "gold"] },
        "subscriptionEndDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "name", "role", "tier", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Messages sent from admin to users",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "receiverId", "title", "content", "isRead", "createdAt"]
    },
    "Material": {
      "title": "Material",
      "description": "Materials uploaded by admin",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "contentUrl": { "type": "string" },
        "category": { "type": "string", "enum": ["ebook", "prompt", "service", "advanced", "webbuilder"] },
        "subCategory": { "type": "string" },
        "requiredTier": { "type": "string", "enum": ["free", "silver", "gold"] },
        "imageUrl": { "type": "string" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "contentUrl", "category", "requiredTier", "authorId", "createdAt"]
    },
    "DeletedUser": {
      "title": "DeletedUser",
      "description": "Records of deleted or kicked users to prevent immediate re-registration",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "deletedAt": { "type": "string", "format": "date-time" },
        "reason": { "type": "string", "enum": ["withdrawal", "kicked"] }
      },
      "required": ["email", "deletedAt", "reason"]
    },
    "AccessSession": {
      "title": "AccessSession",
      "description": "Temporary tokens for automatic login to subsidiary apps",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "tier": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "tier", "createdAt", "expiresAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages sent to users"
    },
    "/materials/{materialId}": {
      "schema": "Material",
      "description": "Materials uploaded by admin"
    },
    "/deleted_users/{email}": {
      "schema": "DeletedUser",
      "description": "Records of deleted users"
    },
    "/access_sessions/{sessionId}": {
      "schema": "AccessSession",
      "description": "Temporary access tokens"
    }
  }
}
